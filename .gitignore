# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Project-local Mix/Hex caches used by agents and containers.
/.hex-home/
/.hex-home_*/
/.hex_home/
/.hex_home_*/
/.mix-home/
/.mix-home_*/
/.mix_home/
/.mix_home_*/

# Editor, language-server, and OS-local files.
/.elixir_ls/
/.vscode/
/.idea/
.DS_Store
*.swp
*.swo

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Dialyzer PLTs are large machine-local artifacts.
/priv/plts/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Phoenix/asset build outputs.
/assets/node_modules/
/priv/static/assets/
/priv/static/cache/

# Local environment and runtime files.
/.env
/.env.*
!.env.example

# Ignore package tarball (built via "mix hex.build").
conveyor-*.tar

.claude/worktrees/
.codescent/
.conveyor/
# Compound Engineering local config
.compound-engineering/*.local.yaml
