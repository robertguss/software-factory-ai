{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.plan_revision@1.json",
  "title": "Conveyor PlanRevision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "revision_no",
    "source_snapshot_ids",
    "normalized_contract_ref",
    "contract_digest",
    "change_class",
    "status",
    "created_by",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.plan_revision@1" },
    "plan_id": { "type": "string", "minLength": 1 },
    "revision_no": { "type": "integer", "minimum": 1 },
    "parent_revision_id": { "type": "string", "minLength": 1 },
    "source_snapshot_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "normalized_contract_ref": { "type": "string", "minLength": 1 },
    "contract_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "change_class": { "enum": ["formatting_only", "semantic"] },
    "status": { "enum": ["draft", "published", "superseded"] },
    "created_by": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
