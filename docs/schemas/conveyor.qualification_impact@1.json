{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.qualification_impact@1.json",
  "title": "Conveyor QualificationImpact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "changed_subject_refs",
    "changed_digest_classes",
    "affected_grant_ids",
    "required_requalification_case_ids",
    "required_conformance_suite_refs",
    "unaffected_evidence_refs",
    "report_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.qualification_impact@1" },
    "id": {
      "type": "string",
      "pattern": "^qualification_impact:sha256:[0-9a-f]{64}$"
    },
    "changed_subject_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "changed_digest_classes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "affected_grant_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^qualification_grant:sha256:[0-9a-f]{64}$"
      }
    },
    "required_requalification_case_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_conformance_suite_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unaffected_evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "report_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
