{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.provider_egress_record@1.json",
  "title": "Conveyor ProviderEgressRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject_ref",
    "provider_contract_digest",
    "role_view_digest",
    "prompt_manifest_digest",
    "input_label_summary",
    "policy_decision_id",
    "trace_id",
    "sent_at"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.provider_egress_record@1" },
    "subject_ref": { "$ref": "#/$defs/subject_ref" },
    "provider_contract_digest": { "$ref": "#/$defs/digest" },
    "role_view_digest": { "$ref": "#/$defs/digest" },
    "prompt_manifest_digest": { "$ref": "#/$defs/digest" },
    "input_label_summary": { "type": "object" },
    "redaction_report_ref": { "$ref": "#/$defs/resource_ref" },
    "policy_decision_id": { "type": "string", "minLength": 1 },
    "provider_request_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "sent_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "resource_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "id_or_key"],
      "properties": {
        "schema_version": { "const": "conveyor.resource_ref@1" },
        "kind": { "type": "string", "minLength": 1 },
        "id_or_key": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "id_or_key"],
      "properties": {
        "schema_version": { "const": "conveyor.subject_ref@1" },
        "kind": { "type": "string", "minLength": 1 },
        "id_or_key": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
