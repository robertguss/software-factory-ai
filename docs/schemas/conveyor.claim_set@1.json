{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.claim_set@1.json",
  "title": "Conveyor ClaimSet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject",
    "subject_content_digest",
    "claims",
    "claim_set_digest"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.claim_set@1" },
    "subject": { "type": "string", "minLength": 1 },
    "subject_content_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "subject_pointer",
          "origin",
          "source_anchor_refs",
          "confidence",
          "impact",
          "approval_status"
        ],
        "properties": {
          "subject_pointer": { "type": "string" },
          "origin": {
            "enum": [
              "human_explicit",
              "repo_observed",
              "deterministic_derived",
              "agent_inferred"
            ]
          },
          "source_anchor_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "impact": { "type": "string", "minLength": 1 },
          "inference_reason": { "type": "string" },
          "approval_status": {
            "enum": ["not_required", "pending", "approved", "rejected"]
          }
        }
      }
    },
    "claim_set_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
