{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.decision_contract@1.json",
  "title": "Conveyor DecisionContract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "decision_key", "version", "subject_kinds", "input_schema_ref", "result_schema_ref", "required_evidence_selectors", "freshness_policy", "default_result", "evaluator_ref", "evaluator_version", "contract_digest"],
  "properties": {
    "schema_version": { "const": "conveyor.decision_contract@1" },
    "decision_key": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "subject_kinds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "input_schema_ref": { "type": "string", "minLength": 1 },
    "result_schema_ref": { "type": "string", "minLength": 1 },
    "required_evidence_selectors": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "freshness_policy": { "type": "string", "minLength": 1 },
    "default_result": { "enum": ["deny", "require_human", "indeterminate"] },
    "evaluator_ref": { "type": "string", "minLength": 1 },
    "evaluator_version": { "type": "string", "minLength": 1 },
    "contract_digest": { "$ref": "#/$defs/digest_ref" }
  },
  "$defs": {
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "algorithm", "value"],
      "properties": {
        "schema_version": { "const": "conveyor.digest_ref@1" },
        "algorithm": { "enum": ["sha256", "sha512", "blake3"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64,128}$" }
      }
    }
  }
}
