{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.test_pack_patch@1.json",
  "title": "Conveyor TestPackPatch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "slice_id",
    "test_pack_id",
    "agent_brief_contract_id",
    "workspace_contract_id",
    "test_specification_ids",
    "patch_files",
    "environment_policy",
    "nondeterminism_policy",
    "result_adapters",
    "test_pack_patch_digest"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.test_pack_patch@1" },
    "id": {
      "type": "string",
      "pattern": "^test_pack_patch:sha256:[0-9a-f]{64}$"
    },
    "slice_id": { "type": "string", "minLength": 1 },
    "test_pack_id": { "type": "string", "minLength": 1 },
    "agent_brief_contract_id": { "type": "string", "minLength": 1 },
    "workspace_contract_id": { "type": "string", "minLength": 1 },
    "test_specification_ids": { "$ref": "#/$defs/non_empty_string_array" },
    "patch_files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/patch_file" }
    },
    "environment_policy": { "$ref": "#/$defs/policy_map" },
    "nondeterminism_policy": { "$ref": "#/$defs/policy_map" },
    "result_adapters": { "$ref": "#/$defs/non_empty_string_array" },
    "test_pack_patch_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "patch_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "mode", "content_digest"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["create", "modify", "delete"] },
        "content_digest": { "type": "string", "minLength": 1 }
      }
    },
    "policy_map": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "array",
          "object",
          "null"
        ]
      }
    }
  }
}
