{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.plan_interrogation@1.json",
  "title": "Conveyor PlanInterrogation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "planning_run_id", "plan_revision_id", "status", "questions", "question_batch_ref", "created_at"],
  "properties": {
    "schema_version": { "const": "conveyor.plan_interrogation@1" },
    "planning_run_id": { "type": "string", "minLength": 1 },
    "plan_revision_id": { "type": "string", "minLength": 1 },
    "interrogator_profile_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["questions_required", "answered", "superseded", "cancelled"] },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question_id", "action", "prompt", "finding_refs"],
        "properties": {
          "question_id": { "type": "string", "minLength": 1 },
          "action": { "const": "ask_human" },
          "prompt": { "type": "string", "minLength": 1 },
          "finding_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "anchor_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "question_batch_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
