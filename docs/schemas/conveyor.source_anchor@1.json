{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.source_anchor@1.json",
  "title": "Conveyor SourceAnchor",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind"],
  "properties": {
    "schema_version": { "const": "conveyor.source_anchor@1" },
    "kind": {
      "enum": [
        "plan_span",
        "repo_symbol",
        "decision",
        "artifact_pointer",
        "policy_rule"
      ]
    },
    "source_blob_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "repository_commit": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "symbol_key": { "type": "string", "minLength": 1 },
    "byte_start": { "type": "integer", "minimum": 0 },
    "byte_end": { "type": "integer", "minimum": 0 },
    "line_start": { "type": "integer", "minimum": 1 },
    "line_end": { "type": "integer", "minimum": 1 },
    "excerpt_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "artifact_ref": { "type": "string", "minLength": 1 },
    "json_pointer": { "type": "string" }
  }
}
