{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.lifecycle_contract@1.json",
  "title": "Conveyor LifecycleContract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "resource_kind", "states", "terminal_states", "transitions"],
  "properties": {
    "schema_version": { "const": "conveyor.lifecycle_contract@1" },
    "resource_kind": { "type": "string", "minLength": 1 },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "terminal_states": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["transition_key", "from", "to_state", "required_event_type"],
        "properties": {
          "transition_key": { "type": "string", "minLength": 1 },
          "from": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "to_state": { "type": "string", "minLength": 1 },
          "required_policy_decision_keys": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "required_authority_inputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "required_event_type": { "type": "string", "minLength": 1 },
          "idempotency_key_shape": { "type": "string", "minLength": 1 },
          "forbidden_when": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
