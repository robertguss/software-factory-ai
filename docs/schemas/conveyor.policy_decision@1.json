{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.policy_decision@1.json",
  "title": "Conveyor PolicyDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "decision_key", "contract_digest", "subject", "input_digest", "evidence_root_digest", "policy_bundle_digest", "result", "reason_codes", "decision_digest", "trace_id"],
  "properties": {
    "schema_version": { "const": "conveyor.policy_decision@1" },
    "decision_key": { "type": "string", "minLength": 1 },
    "contract_digest": { "$ref": "#/$defs/digest_ref" },
    "subject": { "$ref": "#/$defs/subject_ref" },
    "input_digest": { "$ref": "#/$defs/digest_ref" },
    "evidence_root_digest": { "$ref": "#/$defs/digest_ref" },
    "policy_bundle_digest": { "$ref": "#/$defs/digest_ref" },
    "result": { "enum": ["allow", "deny", "require_human", "not_applicable", "indeterminate"] },
    "reason_codes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "explanation_ref": { "type": "string", "minLength": 1 },
    "decision_digest": { "$ref": "#/$defs/digest_ref" },
    "trace_id": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "algorithm", "value"],
      "properties": {
        "schema_version": { "const": "conveyor.digest_ref@1" },
        "algorithm": { "enum": ["sha256", "sha512", "blake3"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64,128}$" }
      }
    },
    "subject_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "id_or_key"],
      "properties": {
        "schema_version": { "const": "conveyor.subject_ref@1" },
        "kind": { "type": "string", "minLength": 1 },
        "id_or_key": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest_ref" }
      }
    }
  }
}
