{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.effect_receipt@1.json",
  "title": "Conveyor EffectReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "effect_attempt_id", "fencing_token", "idempotency_key", "request_digest", "result_digest", "reconciliation_status", "trace_id", "observed_at"],
  "properties": {
    "schema_version": { "const": "conveyor.effect_receipt@1" },
    "effect_attempt_id": { "type": "string", "minLength": 1 },
    "fencing_token": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "external_correlation_id": { "type": "string", "minLength": 1 },
    "request_digest": { "$ref": "#/$defs/digest" },
    "result_digest": { "$ref": "#/$defs/digest" },
    "reconciliation_status": { "enum": ["pending", "confirmed", "absent", "ambiguous", "compensated"] },
    "trace_id": { "type": "string", "minLength": 1 },
    "observed_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
