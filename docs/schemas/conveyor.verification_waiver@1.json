{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.verification_waiver@1.json",
  "title": "Conveyor VerificationWaiver",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "verification_obligation_id",
    "human_decision_id",
    "reason",
    "compensating_control_refs",
    "max_autonomy",
    "owner",
    "expires_at",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.verification_waiver@1" },
    "id": {
      "type": "string",
      "pattern": "^verification_waiver:sha256:[0-9a-f]{64}$"
    },
    "verification_obligation_id": {
      "type": "string",
      "pattern": "^verification_obligation:sha256:[0-9a-f]{64}$"
    },
    "human_decision_id": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "compensating_control_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "max_autonomy": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["active", "expired", "revoked", "superseded"] }
  }
}
