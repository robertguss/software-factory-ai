{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.attestation_statement@1.json",
  "title": "Conveyor AttestationStatement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "_type",
    "subject",
    "predicateType",
    "predicate",
    "signature_status"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.attestation_statement@1" },
    "_type": { "const": "https://in-toto.io/Statement/v1" },
    "subject": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "digest"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "digest": {
            "type": "object",
            "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64,128}$" },
            "minProperties": 1
          }
        }
      }
    },
    "predicateType": { "type": "string", "format": "uri" },
    "predicate": { "type": "object" },
    "signature_status": { "enum": ["unsigned", "locally_signed", "externally_verified"] },
    "verification_bundle_ref": { "type": "string", "minLength": 1 },
    "signer_identity": { "type": "string", "minLength": 1 }
  }
}
