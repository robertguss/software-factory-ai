{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.effect_attempt@1.json",
  "title": "Conveyor EffectAttempt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "station_run_id", "station_effect_id", "fencing_token", "admission_permit_id", "idempotency_key", "request_digest", "started_at", "status"],
  "properties": {
    "schema_version": { "const": "conveyor.effect_attempt@1" },
    "station_run_id": { "type": "string", "minLength": 1 },
    "station_effect_id": { "type": "string", "minLength": 1 },
    "fencing_token": { "type": "string", "minLength": 1 },
    "admission_permit_id": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "request_digest": { "$ref": "#/$defs/digest" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["started", "externally_accepted", "failed", "outcome_unknown"] }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
