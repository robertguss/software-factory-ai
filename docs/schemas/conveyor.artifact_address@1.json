{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.artifact_address@1.json",
  "title": "Conveyor ArtifactAddress",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trust_domain_id", "content_digest", "opaque_storage_key", "storage_backend"],
  "properties": {
    "schema_version": { "const": "conveyor.artifact_address@1" },
    "trust_domain_id": { "type": "string", "minLength": 1 },
    "content_digest": { "$ref": "#/$defs/digest" },
    "ciphertext_digest": { "$ref": "#/$defs/digest" },
    "opaque_storage_key": { "type": "string", "minLength": 1 },
    "encryption_key_ref": { "type": "string", "minLength": 1 },
    "storage_backend": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
