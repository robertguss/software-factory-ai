{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.manual_intervention_artifact@1.json",
  "title": "Conveyor ManualInterventionArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "intervention_kind",
    "subject_ref",
    "content_ref",
    "actor_action_id",
    "reason",
    "affected_refs",
    "materiality_labels",
    "counts_as_generated_success",
    "requires_reapproval",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.manual_intervention_artifact@1" },
    "intervention_kind": {
      "enum": [
        "patch",
        "contract_edit",
        "test_pack",
        "context_note",
        "diagnosis_note",
        "recovery_note",
        "approval_note"
      ]
    },
    "subject_ref": { "$ref": "#/$defs/resource_ref" },
    "base_authority_root_digest": { "$ref": "#/$defs/digest_ref" },
    "content_ref": { "$ref": "#/$defs/resource_ref" },
    "actor_action_id": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "affected_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource_ref" }
    },
    "materiality_labels": {
      "type": "array",
      "items": {
        "enum": [
          "nonmaterial",
          "review_only",
          "material",
          "breaking",
          "acceptance_criteria",
          "obligation",
          "decision",
          "hard_constraint",
          "scope",
          "compatibility",
          "waiver",
          "risk",
          "public_interface"
        ]
      }
    },
    "counts_as_generated_success": { "type": "boolean" },
    "requires_reapproval": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "resource_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "id_or_key"],
      "properties": {
        "schema_version": { "const": "conveyor.resource_ref@1" },
        "kind": { "type": "string", "minLength": 1 },
        "id_or_key": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "project_id": { "type": "string", "minLength": 1 },
        "trust_domain_id": { "type": "string", "minLength": 1 }
      }
    },
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "algorithm", "value"],
      "properties": {
        "schema_version": { "const": "conveyor.digest_ref@1" },
        "algorithm": { "enum": ["sha256", "sha512", "blake3"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64,128}$" }
      }
    }
  }
}
