{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.approval_set@1.json",
  "title": "Conveyor ApprovalSet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject_authority_roots",
    "review_root_digest",
    "approval_policy_digest",
    "approval_ids",
    "threshold_satisfied",
    "active_revocation_events",
    "approval_set_digest"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.approval_set@1" },
    "subject_authority_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["root_kind", "digest"],
        "properties": {
          "root_kind": { "enum": ["shared_authority", "epic_authority"] },
          "epic_key": { "type": "string", "minLength": 1 },
          "digest": { "$ref": "#/$defs/digest_ref" }
        }
      }
    },
    "review_root_digest": { "$ref": "#/$defs/digest_ref" },
    "approval_policy_digest": { "$ref": "#/$defs/digest_ref" },
    "approval_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "threshold_satisfied": { "type": "boolean" },
    "active_revocation_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource_ref" }
    },
    "approval_set_digest": { "$ref": "#/$defs/digest_ref" }
  },
  "$defs": {
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "algorithm", "value"],
      "properties": {
        "schema_version": { "const": "conveyor.digest_ref@1" },
        "algorithm": { "enum": ["sha256", "sha512", "blake3"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64,128}$" }
      }
    },
    "resource_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "id_or_key"],
      "properties": {
        "schema_version": { "const": "conveyor.resource_ref@1" },
        "kind": { "type": "string", "minLength": 1 },
        "id_or_key": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "project_id": { "type": "string", "minLength": 1 },
        "trust_domain_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
