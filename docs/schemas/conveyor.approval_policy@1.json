{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.approval_policy@1.json",
  "title": "Conveyor ApprovalPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_key",
    "version",
    "subject_scope",
    "required_actor_roles",
    "threshold",
    "separation_of_duties_rules",
    "required_acknowledgement_keys",
    "expiry_policy",
    "policy_digest"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.approval_policy@1" },
    "policy_key": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "subject_scope": { "type": "string", "minLength": 1 },
    "required_actor_roles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "threshold": { "type": "integer", "minimum": 1 },
    "separation_of_duties_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_key", "description"],
        "properties": {
          "rule_key": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "required_acknowledgement_keys": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "expiry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["none", "duration", "root_change"] },
        "duration_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "policy_digest": { "$ref": "#/$defs/digest_ref" }
  },
  "$defs": {
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "algorithm", "value"],
      "properties": {
        "schema_version": { "const": "conveyor.digest_ref@1" },
        "algorithm": { "enum": ["sha256", "sha512", "blake3"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64,128}$" }
      }
    }
  }
}
