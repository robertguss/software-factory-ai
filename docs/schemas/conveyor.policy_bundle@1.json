{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.policy_bundle@1.json",
  "title": "Conveyor PolicyBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_bundle_key",
    "version",
    "policy_ref",
    "digest",
    "input_schema_refs",
    "validation_report_ref",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.policy_bundle@1" },
    "policy_bundle_key": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "policy_ref": { "type": "string", "minLength": 1 },
    "digest": { "$ref": "#/$defs/digest_ref" },
    "input_schema_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "validation_report_ref": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "active", "superseded", "revoked"] }
  },
  "$defs": {
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "algorithm", "value"],
      "properties": {
        "schema_version": { "const": "conveyor.digest_ref@1" },
        "algorithm": { "enum": ["sha256", "sha512", "blake3"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64,128}$" }
      }
    }
  }
}
