{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.planning_bundle@1.json",
  "title": "Conveyor PlanningBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "planning_run_id",
    "plan_revision_id",
    "constraint_set_digest",
    "qualification_grant_id",
    "manifest_ref",
    "manifest_digest",
    "shared_authority_root_digest",
    "epic_authority_root_digests",
    "review_root_digest",
    "archive_bundle_root_digest",
    "approval_signature_excluded",
    "projection_path",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.planning_bundle@1" },
    "planning_run_id": { "type": "string", "minLength": 1 },
    "plan_revision_id": { "type": "string", "minLength": 1 },
    "constraint_set_digest": { "$ref": "#/$defs/digest_ref" },
    "qualification_grant_id": { "type": "string", "minLength": 1 },
    "candidate_selection_id": { "type": "string", "minLength": 1 },
    "manifest_ref": { "$ref": "#/$defs/resource_ref" },
    "manifest_digest": { "$ref": "#/$defs/digest_ref" },
    "shared_authority_root_digest": { "$ref": "#/$defs/digest_ref" },
    "epic_authority_root_digests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["epic_key", "digest"],
        "properties": {
          "epic_key": { "type": "string", "minLength": 1 },
          "digest": { "$ref": "#/$defs/digest_ref" }
        }
      }
    },
    "review_root_digest": { "$ref": "#/$defs/digest_ref" },
    "archive_bundle_root_digest": { "$ref": "#/$defs/digest_ref" },
    "approval_signature_excluded": { "const": true },
    "projection_path": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["draft", "approval_ready", "approved", "blocked", "superseded"]
    }
  },
  "$defs": {
    "digest_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "algorithm", "value"],
      "properties": {
        "schema_version": { "const": "conveyor.digest_ref@1" },
        "algorithm": { "enum": ["sha256", "sha512", "blake3"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64,128}$" }
      }
    },
    "resource_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "id_or_key"],
      "properties": {
        "schema_version": { "const": "conveyor.resource_ref@1" },
        "kind": { "type": "string", "minLength": 1 },
        "id_or_key": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "project_id": { "type": "string", "minLength": 1 },
        "trust_domain_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
