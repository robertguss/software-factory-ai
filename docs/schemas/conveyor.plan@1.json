{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.plan@1.json",
  "title": "Conveyor Plan Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "goal",
    "non_goals",
    "requirements",
    "acceptance_criteria",
    "verification_commands",
    "decisions",
    "slices"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.plan@1" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "base_ref"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "base_ref": { "type": "string", "minLength": 1 }
      }
    },
    "goal": { "type": "string", "minLength": 1 },
    "non_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/requirement" }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/acceptance_criterion" }
    },
    "verification_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/verification_command" }
    },
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision" }
    },
    "slices": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slice" }
    }
  },
  "$defs": {
    "key": { "type": "string", "pattern": "^[A-Z]+-[0-9]{3}$" },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "text", "risk", "source_ref"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "text": { "type": "string", "minLength": 1 },
        "risk": { "enum": ["low", "medium", "high"] },
        "source_ref": { "type": "string", "minLength": 1 },
        "status": { "enum": ["covered", "deferred", "out_of_scope", "open"] }
      }
    },
    "acceptance_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "text", "requirement_refs", "required_test_refs"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "text": { "type": "string", "minLength": 1 },
        "requirement_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/key" }
        },
        "required_test_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "verification_command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "argv", "profile"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "profile": { "enum": ["explore", "implement", "verify", "release", "maintenance"] }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "decision", "rationale"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "decision": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "slice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "title",
        "requirement_refs",
        "likely_files",
        "conflict_domains",
        "autonomy_ceiling"
      ],
      "properties": {
        "key": { "type": "string", "pattern": "^SLICE-[0-9]{3}$" },
        "title": { "type": "string", "minLength": 1 },
        "requirement_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/key" }
        },
        "likely_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "conflict_domains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "autonomy_ceiling": { "enum": ["L0", "L1", "L2", "L3", "L4"] }
      }
    }
  }
}
