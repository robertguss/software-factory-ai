{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.actor_identity@1.json",
  "title": "Conveyor ActorIdentity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "actor_id",
    "actor_kind",
    "display_name",
    "auth_provider",
    "roles",
    "trust_domain_id",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.actor_identity@1" },
    "actor_id": { "type": "string", "minLength": 1 },
    "actor_kind": { "enum": ["human", "agent", "service", "local_unsigned"] },
    "display_name": { "type": "string", "minLength": 1 },
    "auth_provider": { "type": "string", "minLength": 1 },
    "verified_identity_ref": { "type": "string", "minLength": 1 },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "trust_domain_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["active", "suspended", "retired"] }
  }
}
