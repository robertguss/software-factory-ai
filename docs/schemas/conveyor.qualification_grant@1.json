{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.qualification_grant@1.json",
  "title": "Conveyor QualificationGrant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "project_id",
    "qualification_gate_run_id",
    "evidence_root_digest",
    "scope_ref",
    "scope_digest",
    "adapter_class",
    "agent_class",
    "archetype_class",
    "change_class",
    "toolchain_class",
    "risk_class",
    "policy_digest",
    "environment_digest",
    "deployment_digest",
    "max_autonomy",
    "success_rate_bands",
    "limitations",
    "waiver_refs",
    "issued_at",
    "invalidation_triggers",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.qualification_grant@1" },
    "id": { "type": "string", "pattern": "^qualification_grant:sha256:[0-9a-f]{64}$" },
    "project_id": { "type": "string", "minLength": 1 },
    "qualification_gate_run_id": { "type": "string", "minLength": 1 },
    "evidence_root_digest": { "$ref": "#/$defs/digest" },
    "scope_ref": { "type": "string", "minLength": 1 },
    "scope_digest": { "$ref": "#/$defs/digest" },
    "adapter_class": { "type": "string", "minLength": 1 },
    "agent_class": { "type": "string", "minLength": 1 },
    "archetype_class": { "type": "string", "minLength": 1 },
    "change_class": { "type": "string", "minLength": 1 },
    "toolchain_class": { "type": "string", "minLength": 1 },
    "risk_class": { "type": "string", "minLength": 1 },
    "policy_digest": { "$ref": "#/$defs/digest" },
    "environment_digest": { "$ref": "#/$defs/digest" },
    "deployment_digest": { "$ref": "#/$defs/digest" },
    "max_autonomy": { "type": "string", "minLength": 1 },
    "success_rate_bands": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/success_rate_band" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "waiver_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "invalidation_triggers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "status": { "enum": ["active", "expired", "revoked", "superseded"] }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "success_rate_band": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "lower_bound", "upper_bound", "sample_count", "policy_ref"],
      "properties": {
        "capability": { "type": "string", "minLength": 1 },
        "lower_bound": { "type": "number", "minimum": 0, "maximum": 1 },
        "upper_bound": { "type": "number", "minimum": 0, "maximum": 1 },
        "sample_count": { "type": "integer", "minimum": 0 },
        "policy_ref": { "type": "string", "minLength": 1 }
      }
    }
  }
}
