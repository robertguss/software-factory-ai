{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.gate@1.json",
  "title": "Conveyor Gate Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_spec_sha256",
    "verdict",
    "stages",
    "stop_the_line",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.gate@1" },
    "run_spec_sha256": { "$ref": "#/$defs/sha256" },
    "verdict": {
      "enum": ["passed", "failed", "needs_rework", "policy_blocked"]
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "status", "evidence_refs"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "skipped"] },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "stop_the_line": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
