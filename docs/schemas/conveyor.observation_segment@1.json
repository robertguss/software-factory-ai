{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conveyor.dev/schemas/conveyor.observation_segment@1.json",
  "title": "Conveyor ObservationSegment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_ref",
    "sequence_start",
    "sequence_end",
    "sensitivity",
    "digest",
    "storage_pointer"
  ],
  "properties": {
    "schema_version": { "const": "conveyor.observation_segment@1" },
    "manifest_ref": { "$ref": "#/$defs/resource_ref" },
    "sequence_start": { "type": "integer", "minimum": 0 },
    "sequence_end": { "type": "integer", "minimum": 0 },
    "sensitivity": {
      "enum": ["public", "internal", "restricted", "secret_ref"]
    },
    "digest": { "$ref": "#/$defs/digest" },
    "storage_pointer": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "resource_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "id_or_key"],
      "properties": {
        "schema_version": { "const": "conveyor.resource_ref@1" },
        "kind": { "type": "string", "minLength": 1 },
        "id_or_key": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
