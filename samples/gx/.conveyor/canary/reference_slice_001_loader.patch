+    """Parse an edge-list file into a canonical :class:`Graph`."""
+    node_set: set[str] = set()
+    edge_set: set[tuple[str, str]] = set()
+
+    with open(path, "r", encoding="utf-8") as handle:
+        for line_number, raw in enumerate(handle, start=1):
+            line = raw.strip()
+            if not line or line.startswith("#"):
+                continue
+            tokens = line.split()
+            if len(tokens) == 1:
+                node_set.add(tokens[0])
+            elif len(tokens) == 2:
+                src, dst = tokens
+                node_set.update((src, dst))
+                edge_set.add((src, dst))
+            else:
+                raise LoaderError(
+                    f"expected 'SRC DST' or a single node, got {len(tokens)} tokens",
+                    line_number=line_number,
+                )
+
+    nodes = tuple(sorted(node_set))
+    edges = tuple(sorted(edge_set))
+
+    succ: dict[str, list[str]] = {node: [] for node in nodes}
+    pred: dict[str, list[str]] = {node: [] for node in nodes}
+    for src, dst in edges:
+        succ[src].append(dst)
+        pred[dst].append(src)
+
+    successors = {node: tuple(sorted(set(neighbours))) for node, neighbours in succ.items()}
+    predecessors = {node: tuple(sorted(set(neighbours))) for node, neighbours in pred.items()}
+
+    return Graph(nodes=nodes, edges=edges, successors=successors, predecessors=predecessors)
