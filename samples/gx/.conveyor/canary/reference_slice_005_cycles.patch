+def _canonical(cycle: list[str]) -> tuple[str, ...]:
+    """Rotate a cycle so it starts at its lexicographically smallest node."""
+    pivot = min(range(len(cycle)), key=cycle.__getitem__)
+    return tuple(cycle[pivot:] + cycle[:pivot])
