+    edge_sets = {
+        "blocks_edges": blocks_edges,
+        "parent_edges": parent_edges,
+        "related_edges": related_edges,
+    }
+
+    with open(path, "r", encoding="utf-8") as handle:
+        for line_number, raw_line in enumerate(handle, start=1):
+            stripped = raw_line.strip()
+            if not stripped:
+                # Tolerate blank lines (notably the trailing newline at EOF).
+                continue
+            try:
+                record = json.loads(stripped)
+            except json.JSONDecodeError as exc:
+                raise LoaderError(
+                    f"malformed JSON on line {line_number}: {exc}",
+                    line_number=line_number,
+                ) from exc
+
+            issue = _build_issue(record)
+            issues[issue.id] = issue
+
+            # Build canonical src -> dst edges from this record's dependencies[].
+            for dep in record.get("dependencies") or ():
+                attr = _EDGE_KIND_TO_ATTR.get(dep.get("type"))
+                if attr is None:
+                    # Forward-compatible: unknown edge kinds are ignored.
+                    continue
+                src = dep["depends_on_id"]
+                dst = issue.id
+                edge_sets[attr].add((src, dst))
+
+    return IssueGraph(
+        issues=issues,
+        blocks_edges=blocks_edges,
+        parent_edges=parent_edges,
+        related_edges=related_edges,
+    )
