+def ready_issues(graph: IssueGraph):
+    """Return the ready issues sorted by ``(priority asc, id asc)``.
+
+    An issue is ready when it is ``open`` and every ``blocks`` edge pointing at it
+    originates from a ``closed`` issue. Parent-child and related edges never gate.
+    """
+    # Map each issue id -> the set of issue ids that block it (incoming blocks edges).
+    blockers: dict[str, set[str]] = {}
+    for src, dst in graph.blocks_edges:
+        blockers.setdefault(dst, set()).add(src)
+
+    ready = []
+    for issue in graph.issues.values():
+        if issue.status != "open":
+            continue
+        incoming = blockers.get(issue.id, set())
+        if all(
+            issue_id in graph.issues and graph.issues[issue_id].status == "closed"
+            for issue_id in incoming
+        ):
+            ready.append(issue)
+
+    ready.sort(key=lambda i: (i.priority, i.id))
+    return ready
+
+
+def _rows(graph: IssueGraph):
+    return [
+        {"id": issue.id, "priority": issue.priority, "title": issue.title}
+        for issue in ready_issues(graph)
+    ]
+

