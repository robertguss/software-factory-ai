+def _canonical_rotation(cycle: list[str]) -> tuple[str, ...]:
+    """Return the lexicographically-smallest rotation of a cycle's node ids.
+
+    ``cycle`` is the node sequence of an elementary circuit (no repeated node, and
+    the closing edge back to ``cycle[0]`` is implied). The canonical form rotates so
+    the smallest id leads, giving one stable representative per cycle.
+    """
+    n = len(cycle)
+    best_index = min(range(n), key=lambda i: cycle[i])
+    return tuple(cycle[best_index:] + cycle[:best_index])
