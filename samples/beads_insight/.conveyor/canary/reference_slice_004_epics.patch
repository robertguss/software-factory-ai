+def _descendants(graph: IssueGraph, root: str) -> list[str]:
+    """Return the transitive parent-child descendants of ``root`` (excluding root).
+
+    Walks ``parent_edges`` (parent -> child) breadth-first; the result is sorted so
+    downstream rendering is deterministic. Cyclic parent edges (should not occur) are
+    guarded by a visited set.
+    """
+    children: dict[str, list[str]] = {}
+    for src, dst in graph.parent_edges:
+        children.setdefault(src, []).append(dst)
+
+    seen: set[str] = set()
+    stack = list(children.get(root, ()))
+    while stack:
+        node = stack.pop()
+        if node in seen:
+            continue
+        seen.add(node)
+        stack.extend(children.get(node, ()))
+    return sorted(seen)
+
+
+def _is_blocked(graph: IssueGraph, issue_id: str) -> bool:
+    """True when ``issue_id`` has an incoming blocks edge from a non-closed issue."""
+    for src, dst in graph.blocks_edges:
+        if dst != issue_id:
+            continue
+        blocker = graph.issues.get(src)
+        if blocker is None or blocker.status != "closed":
+            return True
+    return False
+
+
+def epic_rollups(graph: IssueGraph):
+    """Return per-epic rollup dicts sorted by epic id.
+
+    Each rollup: ``{id, title, total, closed, pct, open, blocked}``. ``pct`` is the
+    integer floor of ``100 * closed / total``; a childless epic reports total=0 and
+    pct=100 (and never divides by zero).
+    """
+    rollups = []
+    epics = [i for i in graph.issues.values() if i.issue_type == "epic"]
+    for epic in sorted(epics, key=lambda i: i.id):
+        descendants = _descendants(graph, epic.id)
+        total = len(descendants)
+        closed = sum(
+            1 for d in descendants
+            if d in graph.issues and graph.issues[d].status == "closed"
+        )
+        open_count = sum(
+            1 for d in descendants
+            if d in graph.issues and graph.issues[d].status == "open"
+        )
+        blocked = sum(
+            1 for d in descendants
+            if d in graph.issues
+            and graph.issues[d].status == "open"
+            and _is_blocked(graph, d)
+        )
+        pct = 100 if total == 0 else (100 * closed) // total
+        rollups.append(
+            {
+                "id": epic.id,
+                "title": epic.title,
+                "total": total,
+                "closed": closed,
+                "pct": pct,
+                "open": open_count,
+                "blocked": blocked,
+            }
+        )
+    return rollups
+

