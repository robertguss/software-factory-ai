+                dst = dependency.get("issue_id", issue_id)
+                dependency_type = dependency["type"]
+                if dependency_type == "blocks":
+                    blocks_edges.add((src, dst))
+                elif dependency_type == "parent-child":
+                    parent_edges.add((src, dst))
+                elif dependency_type == "related":
+                    related_edges.add((src, dst))
+
+    return IssueGraph(
+        issues=issues,
+        blocks_edges=blocks_edges,
+        parent_edges=parent_edges,
+        related_edges=related_edges,
