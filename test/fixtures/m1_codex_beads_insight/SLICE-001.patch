         self.line_number = line_number
 
 
+def _parse_datetime(value: str | None) -> datetime | None:
+    if value is None:
+        return None
+    return datetime.fromisoformat(value.replace("Z", "+00:00"))
+
+
 def load(path) -> IssueGraph:
     """Parse a ``.beads/issues.jsonl`` export into an :class:`IssueGraph`.
-
-    STUB — implemented in SLICE-001.
     """
-    raise NotImplementedError("loader.load is implemented in SLICE-001")
+    issues: dict[str, Issue] = {}
+    blocks_edges: set[tuple[str, str]] = set()
+    parent_edges: set[tuple[str, str]] = set()
+    related_edges: set[tuple[str, str]] = set()
+
+    with open(path, encoding="utf-8") as handle:
+        for line_number, line in enumerate(handle, start=1):
+            try:
+                record = json.loads(line)
+            except json.JSONDecodeError as exc:
+                raise LoaderError(str(exc), line_number=line_number) from exc
+
+            issue_id = record["id"]
+            issues[issue_id] = Issue(
